generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RoleName {
  admin
  editor
  viewer
}

enum UnitType {
  weight
  volume
  count
  length
}

// ─── Auth Domain ──────────────────────────────────────────────────────────────

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  username      String   @unique @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  password_hash String
  first_name    String
  last_name     String
  created_at    DateTime @default(now())

  ownedGroups   Group[]
  userGroups    UserGroup[]
  recipes       Recipe[]
  shoppingLists ShoppingList[]
  sharedRecipes RecipeGroup[]  @relation("SharedBy")
  refresh_tokens RefreshToken[]
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?

  userGroups UserGroup[]
}

model Group {
  id          String  @id @default(uuid()) @db.Uuid
  owner_id    String  @db.Uuid
  name        String  @db.VarChar(100)
  description String?

  owner        User          @relation(fields: [owner_id], references: [id])
  userGroups   UserGroup[]
  recipeGroups RecipeGroup[]
}

model UserGroup {
  user_id   String   @db.Uuid
  role_id   String   @db.Uuid
  group_id  String   @db.Uuid
  is_owner  Boolean  @default(false)
  joined_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id])
  role  Role  @relation(fields: [role_id], references: [id])
  group Group @relation(fields: [group_id], references: [id])

  @@id([user_id, group_id])
}

// ─── Lookup Domain ────────────────────────────────────────────────────────────

model Unit {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique @db.VarChar(50)
  abbreviation String   @db.VarChar(10)
  unit_type    UnitType

  ingredients   Ingredient[]
  shoppingItems ShoppingItem[]
}

// ─── Core Domain ─────────────────────────────────────────────────────────────

model Recipe {
  id                String   @id @default(uuid()) @db.Uuid
  author_id         String   @db.Uuid
  title             String   @db.VarChar(200)
  description       String?
  time_required_min Int?
  difficulty        String?  @db.VarChar(20)
  servings          Int?
  is_public         Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  author      User          @relation(fields: [author_id], references: [id])
  ingredients Ingredient[]
  steps       CookingStep[]
  images      RecipeImage[]
  tags        RecipeTag[]
  groups      RecipeGroup[]
}

model Ingredient {
  id         String  @id @default(uuid()) @db.Uuid
  recipe_id  String  @db.Uuid
  unit_id    String  @db.Uuid
  name       String  @db.VarChar(150)
  quantity   Decimal @db.Decimal(10, 2)
  calories   Decimal? @db.Decimal(10, 2)
  protein_g  Decimal? @db.Decimal(10, 2)
  carbs_g    Decimal? @db.Decimal(10, 2)
  fat_g      Decimal? @db.Decimal(10, 2)
  sort_order Int     @default(0)

  recipe        Recipe         @relation(fields: [recipe_id], references: [id])
  unit          Unit           @relation(fields: [unit_id], references: [id])
  shoppingItems ShoppingItem[]
}

model CookingStep {
  id           String @id @default(uuid()) @db.Uuid
  recipe_id    String @db.Uuid
  step_number  Int
  instruction  String
  duration_min Int?

  recipe Recipe @relation(fields: [recipe_id], references: [id])
}

model Tag {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(50)

  recipes RecipeTag[]
}

model RecipeTag {
  recipe_id String @db.Uuid
  tag_id    String @db.Uuid

  recipe Recipe @relation(fields: [recipe_id], references: [id])
  tag    Tag    @relation(fields: [tag_id], references: [id])

  @@id([recipe_id, tag_id])
}

model RecipeImage {
  id          String   @id @default(uuid()) @db.Uuid
  recipe_id   String   @db.Uuid
  storage_url String
  provider    String
  storage_key String
  is_primary  Boolean  @default(false)
  mime_type   String   @db.VarChar(50)
  uploaded_at DateTime @default(now())

  recipe Recipe @relation(fields: [recipe_id], references: [id])
}

// ─── Shopping Domain ──────────────────────────────────────────────────────────

model ShoppingList {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  name         String    @db.VarChar(100)
  is_complete  Boolean   @default(false)
  completed_at DateTime?

  user  User           @relation(fields: [user_id], references: [id])
  items ShoppingItem[]
}

model ShoppingItem {
  id            String   @id @default(uuid()) @db.Uuid
  list_id       String   @db.Uuid
  ingredient_id String?  @db.Uuid
  unit_id       String   @db.Uuid
  custom_name   String?  @db.VarChar(50)
  quantity      Decimal  @db.Decimal(10, 2)
  is_checked    Boolean  @default(false)

  list       ShoppingList @relation(fields: [list_id], references: [id])
  ingredient Ingredient?  @relation(fields: [ingredient_id], references: [id])
  unit       Unit         @relation(fields: [unit_id], references: [id])
}

// ─── Junction Domain ──────────────────────────────────────────────────────────

model RecipeGroup {
  group_id    String   @db.Uuid
  recipe_id   String   @db.Uuid
  shared_by   String   @db.Uuid
  can_comment Boolean  @default(false)
  shared_at   DateTime @default(now())

  group  Group  @relation(fields: [group_id], references: [id])
  recipe Recipe @relation(fields: [recipe_id], references: [id])
  user   User   @relation("SharedBy", fields: [shared_by], references: [id])

  @@id([group_id, recipe_id])
}
